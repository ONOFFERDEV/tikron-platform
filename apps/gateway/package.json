{
  "name": "@tikron/gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:demo && pnpm build:dashboard && wrangler dev",
    "deploy": "pnpm build:demo && pnpm build:dashboard && wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "build:demo": "esbuild demo/agar-client.ts --bundle --format=esm --outfile=public/agar.js --sourcemap",
    "build:dashboard": "pnpm --filter @tikron/dashboard build && node scripts/copy-dashboard.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tikron/protocol": "workspace:*",
    "@tikron/schema": "workspace:*",
    "@tikron/server": "workspace:*",
    "partyserver": "^0.5.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260701.1",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.106.0"
  }
}
