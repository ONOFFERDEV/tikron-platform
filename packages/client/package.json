{
  "name": "@tikron/client",
  "version": "0.1.0",
  "description": "Browser SDK for Tikron — GameClient (matchmake/joinOrCreate) and Room (send, onStateChange, prediction, clock sync) over PartySocket.",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "keywords": ["tikron", "multiplayer", "realtime", "game", "websocket", "client", "sdk", "netcode"],
  "homepage": "https://tikron.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ONOFFERDEV/tikron-platform.git",
    "directory": "packages/client"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tikron/protocol": "workspace:*",
    "@tikron/schema": "workspace:*",
    "partysocket": "^1.1.4"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
