{
  "name": "@tikron/protocol",
  "version": "0.5.0",
  "description": "Shared wire protocol for Tikron — message tags and the JSON envelope codec between the client SDK and the room server.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "keywords": ["tikron", "multiplayer", "realtime", "websocket", "protocol", "game", "netcode"],
  "homepage": "https://tikron.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ONOFFERDEV/tikron-platform.git",
    "directory": "packages/protocol"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
