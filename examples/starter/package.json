{
  "name": "tikron-starter",
  "version": "0.0.0",
  "private": true,
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:client && wrangler dev",
    "deploy": "pnpm build:client && wrangler deploy",
    "build": "pnpm build:client && wrangler deploy --dry-run --outdir dist",
    "build:client": "esbuild client/main.ts --bundle --format=esm --outfile=public/client.js --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "@tikron/client": "workspace:*",
    "@tikron/server": "workspace:*",
    "partyserver": "^0.5.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "esbuild": "^0.28.1",
    "wrangler": "^4.106.0"
  }
}
