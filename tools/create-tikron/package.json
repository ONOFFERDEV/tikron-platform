{
  "name": "create-tikron",
  "version": "0.6.1",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "description": "Scaffold a standalone Tikron multiplayer game (Cloudflare Workers + Durable Objects).",
  "bin": {
    "create-tikron": "dist/index.js"
  },
  "files": ["dist", "templates"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ONOFFERDEV/tikron-platform.git"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": ["tikron", "multiplayer", "cloudflare", "durable-objects", "game", "websocket", "create"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.3"
  }
}
